{
  "blueprint_name": "agency-luxury",
  "description": "Luxury digital agency website type with portfolio, services, and team sections",
  "data_structure": [
    {
      "table_name": "basis",
      "columns": [
        {"name": "naam", "description": "De naam van het bureau", "type": "text", "required": true},
        {"name": "tagline", "description": "Korte slogan of tagline", "type": "text", "required": false},
        {"name": "beschrijving", "description": "Uitgebreide beschrijving van het bureau", "type": "textarea", "required": true},
        {"name": "website", "description": "Website URL", "type": "url", "required": false},
        {"name": "email", "description": "Contact email", "type": "email", "required": true},
        {"name": "telefoon", "description": "Telefoonnummer", "type": "text", "required": false}
      ]
    },
    {
      "table_name": "diensten",
      "columns": [
        {"name": "dienst_naam", "description": "Naam van de dienst", "type": "text", "required": true},
        {"name": "dienst_beschrijving", "description": "Beschrijving van de dienst", "type": "textarea", "required": true},
        {"name": "prijs", "description": "Prijs of prijsindicatie", "type": "text", "required": false}
      ]
    },
    {
      "table_name": "portfolio",
      "columns": [
        {"name": "project_naam", "description": "Naam van het project", "type": "text", "required": true},
        {"name": "client", "description": "Naam van de client", "type": "text", "required": true},
        {"name": "project_beschrijving", "description": "Beschrijving van het project", "type": "textarea", "required": true},
        {"name": "afbeelding_url", "description": "URL naar project afbeelding", "type": "url", "required": false}
      ]
    },
    {
      "table_name": "team",
      "columns": [
        {"name": "naam", "description": "Naam van teamlid", "type": "text", "required": true},
        {"name": "functie", "description": "Functie of rol", "type": "text", "required": true},
        {"name": "bio", "description": "Korte biografie", "type": "textarea", "required": false},
        {"name": "afbeelding_url", "description": "URL naar profielfoto", "type": "url", "required": false}
      ]
    }
  ],
  "design_system": {
    "colors": {
      "primary": "#1e293b",
      "secondary": "#64748b", 
      "accent": "#3b82f6",
      "background": "#ffffff",
      "surface": "#f8fafc"
    },
    "radius": "1rem",
    "font_sans": "'Inter', sans-serif",
    "font_serif": "'Playfair Display', serif"
  },
  "page_structure": {
    "home": ["hero", "diensten", "portfolio", "team", "contact"],
    "overons": ["hero", "beschrijving", "team"],
    "diensten": ["hero", "diensten_lijst"],
    "portfolio": ["hero", "projecten"],
    "contact": ["hero", "contact_formulier"]
  }
}