# Athena CMS - Environment Template (.env)
# Kopieer dit bestand naar .env en vul de juiste waarden in.

### --- Systeem Configuratie ---
ROOT_DIR=/home/user/athena-x
ATHENA_ROOT=/home/user/athena-x


### --- AI Model Configuratie & Survival Waterfall ---
# API Keys
GEMINI_API_KEY=sk-your-gemini-key
OPENROUTER_API_KEY=sk-or-v1-your-key
GROQ_API_KEY=gsk_your-key
HF_TOKEN=hf_your-key
DEEPSEEK_API_KEY=sk-your-key

# Model Stacks per taak
AI_MODEL_DATA_ARCHITECT="gemini-2.5-flash,google/gemini-2.0-flash-exp:free"
AI_MODEL_SITETYPE_PROMPT_ENGINEER="gemini-2.5-flash,google/gemini-2.0-flash-exp:free"
AI_MODEL_PARSER="deepseek-r1-distill-llama-70b,gemini-2.5-flash"
AI_MODEL_IMAGE_GENERATOR="gemini-2.5-flash,google/gemini-2.0-flash-exp:free"
AI_MODEL_DEFAULT="gemini-2.5-flash"


### --- GitHub Integratie ---
GITHUB_USER=athenacmsfactory
GITHUB_PAT=ghp_your-token
GITHUB_ORG=athena-cms-factory
GITHUB_SSH_HOST=github-athena


### --- Server Poorten ---
DASHBOARD_PORT=3001
DOCK_PORT=3000
LAYOUT_EDITOR_PORT=3030
MEDIA_MAPPER_PORT=3031
PREVIEW_PORT=4000


### --- Google Cloud / Sheets ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token
MASTER_TEMPLATE_ID=1_your-template-sheet-id
DRIVE_PROJECTS_FOLDER_ID=your-drive-folder-id


### --- Payment Gateways ---
# STRIPE (Primair voor Bancontact/Payconiq, Creditcard, PayPal)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# MOLLIE (Alternatief)
MOLLIE_API_KEY=test_...


### --- Mail & Athena Gateway ---
# Gebruikt voor de IMAP e-mail koppeling en automatische updates
MAIL_HOST=imap.gmail.com
MAIL_PORT=993
MAIL_USER=athena.cms.agent@gmail.com
MAIL_PASS=your-app-password
