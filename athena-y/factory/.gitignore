# Athena CMS Factory - Root Gitignore

# Dependencies
node_modules/
.pnpm-store/

# Omgevingsvariabelen & Geheimen (CRUCIAAL)
.env
!.gitmodules
!input/**/.gitkeep
!sites/**/.gitkeep

# Specifieke uitzondering voor service accounts die we WEL willen negeren
sheet-service-account.json
service-account.json
*-service-account.json
oauth_credentials.json


# Project Data
# We negeren de inhoud van de projecten, maar behouden de mappenstructuur via .gitkeep
input/*/
!input/.gitkeep

# Sites
# Sites worden als submodules beheerd. We negeren de mappen hier om 
# conflicten met de main repo te voorkomen als ze geen submodule zijn.
sites/*/
!sites/.gitkeep

# AI & Parser resultaten (bron data)
**/tsv-data/
**/input/

# We willen TSV bestanden in input WEL tracken
# Maar elders misschien niet.
!input/**/*.tsv

# Logs & Systeem
*.log
.DS_Store
.vscode/
.idea/
dist/
.temp/
tmp/