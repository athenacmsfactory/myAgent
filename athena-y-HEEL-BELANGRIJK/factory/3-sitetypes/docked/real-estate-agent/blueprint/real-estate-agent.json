{
  "blueprint_name": "real-estate-agent",
  "description": "Professionele website voor vastgoedkantoren met aanbod-beheer en agent-profielen.",
  "features": {
    "ecommerce": false,
    "property_filters": true,
    "search_context": "Vastgoedkantoor te koop te huur woning appartement"
  },
  "data_structure": [
    {
      "table_name": "basis",
      "columns": ["bedrijfsnaam", "titel", "ondertitel", "hero_foto"]
    },
    {
      "table_name": "aanbod",
      "columns": ["titel", "prijs", "locatie", "slaapkamers", "oppervlakte", "foto", "status"]
    },
    {
      "table_name": "agenten",
      "columns": ["naam", "functie", "telefoon", "email", "foto"]
    },
    {
      "table_name": "reviews",
      "columns": ["klant", "quote", "datum"]
    },
    {
      "table_name": "contact",
      "columns": ["adres", "telefoon", "email", "maps_url"]
    }
  ]
}
