{
  "blueprint_name": "premium-webshop-filter",
  "description": "Een geavanceerde webshop met interactieve productfiltering op basis van categorieën. Ideaal voor mode, schoenen en elektronica.",
  "track": "docked",
  "data_structure": [
    {
      "table_name": "basisgegevens",
      "columns": [
        { "name": "site_naam" },
        { "name": "titel" },
        { "name": "ondertitel" },
        { "name": "hero_afbeelding" },
        { "name": "cta_label" },
        { "name": "cta_url" }
      ]
    },
    {
      "table_name": "categorieen",
      "columns": [
        { "name": "naam", "description": "De naam van de categorie (bv. 'Running')." },
        { "name": "slug", "description": "SEO slug." }
      ]
    },
    {
      "table_name": "producten",
      "columns": [
        { "name": "id" },
        { "name": "naam" },
        { "name": "categorie", "description": "MOET exact overeenkomen met een categorie-naam voor filtering." },
        { "name": "prijs" },
        { "name": "beschrijving" },
        { "name": "afbeelding" }
      ]
    }
  ],
  "design_system": {
    "colors": {
      "primary": "#0f172a",
      "accent": "#3b82f6",
      "background": "#ffffff",
      "surface": "#f8fafc"
    },
    "radius": "1.5rem"
  }
}
